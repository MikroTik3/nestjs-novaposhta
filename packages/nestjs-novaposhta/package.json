{
       "name": "nestjs-novaposhta",
       "version": "1.0.0",
       "description": "A NestJS library for integrating with Novaposhta API",
       "author": {
              "name": "Artur Docenko",
              "url": "https://docenko.vercel.app"
       },
       "contributors": [
              {
                     "name": "Artur Docenko",
                     "email": "dotsenk20034@gmail.com"
              }
       ],
       "keywords": [
              "nest",
              "nestjs",
              "nestjs-module",
              "novaposhta",
              "delivery"
       ],
       "license": "MIT",
       "repository": "git@github.com:MikroTik3/nestjs-novaposhta.git",
       "main": "./dist/index.js",
       "types": "./dist/index.d.ts",
       "scripts": {
              "build": "tsc -p tsconfig.json",
              "precommit": "lint-staged",
              "prepublish:npm": "npm run build",
              "publish:npm": "npm publish --access public",
              "format": "prettier --write \"src/**/*.ts\"",
              "lint": "eslint \"{src,apps,libs}/**/*.ts\" --fix"
       },
       "dependencies": {
              "axios": "^1.13.5",
              "rxjs": "^7.8.1",
              "undici": "^6.22.0"
       },
       "devDependencies": {
              "@nestjs/cli": "^11.0.0",
              "@nestjs/common": "^11.0.17",
              "@nestjs/core": "^11.0.17",
              "@nestjs/schematics": "^11.0.0",
              "@types/express": "^5.0.0",
              "@types/node": "^22.10.7",
              "globals": "^16.0.0",
              "source-map-support": "^0.5.21",
              "ts-loader": "^9.5.2",
              "ts-node": "^10.9.2",
              "tsconfig-paths": "^4.2.0",
              "typescript": "^5.7.3"
       }
}